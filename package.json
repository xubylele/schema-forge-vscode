{
  "name": "schema-forge",
  "publisher": "xubylele",
  "author": {
    "name": "xubylele",
    "email": "diazxavier27@gmail.com"
  },
  "displayName": "Schema Forge",
  "description": "Official VS Code extension for Schema Forge. Provides language support and tooling for the Schema Forge DSL (.sf).",
  "version": "0.2.1",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/xubylele/schema-forge",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "schema-forge",
    "vscode",
    "dsl",
    "database",
    "postgres",
    "migration",
    "schema"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xubylele/schema-forge-vscode.git"
  },
  "activationEvents": [
    "onLanguage:schema-forge",
    "onCommand:schemaForge.init",
    "onCommand:schemaForge.generate",
    "onCommand:schemaForge.diff"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "schema-forge",
        "aliases": [
          "Schema Forge",
          "schema-forge"
        ],
        "extensions": [
          ".sf"
        ]
      }
    ],
    "grammars": [
      {
        "language": "schema-forge",
        "scopeName": "source.schemaforge",
        "path": "./syntaxes/schemaforge.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "schema-forge",
        "path": "./snippets/schemaforge.json"
      }
    ],
    "commands": [
      {
        "command": "schemaForge.init",
        "title": "Schema Forge: Init"
      },
      {
        "command": "schemaForge.generate",
        "title": "Schema Forge: Generate"
      },
      {
        "command": "schemaForge.diff",
        "title": "Schema Forge: Diff"
      }
    ]
  },
  "dependencies": {
    "@xubylele/schema-forge-core": "^1.1.0"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "npm-run-all -p watch:esbuild watch:tsc",
    "watch:esbuild": "node esbuild.config.js --watch",
    "watch:tsc": "tsc --noEmit --watch --preserveWatchOutput",
    "vscode:prepublish": "npm run build",
    "package:vsix": "npx vsce package",
    "publish:stable": "npx vsce publish",
    "publish:pre-release": "npx vsce publish --pre-release",
    "lint": "NODE_OPTIONS=--max-old-space-size=4096 eslint .",
    "pretest": "npm run build",
    "test": "node ./dist/test/test/runTest.js",
    "test:unit": "npm run build && node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "changeset": "^0.2.6",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
